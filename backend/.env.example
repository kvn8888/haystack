# =============================================================================
# HayStack backend — environment configuration
# Copy this file to backend/.env (or repo-root .env) and fill in real values
# for the integrations you want to run live. Anything left blank stays mocked.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8787
HAYSTACK_PUBLIC_BASE_URL=http://localhost:8787

# Author shown as the logged-in writer in the composer + dashboard.
# Must match a key in frontend/src/utils.ts AUTHORS map (author_ada, author_river, ...)
HAYSTACK_DEFAULT_AUTHOR_ID=author_ada

# -----------------------------------------------------------------------------
# Google Gemini  (https://aistudio.google.com/app/apikey)
# When GEMINI_API_KEY is set, /api/agent/query runs a real Gemini
# function-calling loop instead of the local mock.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-flash-latest
GEMINI_PRO_MODEL=gemini-pro-latest
AGENT_DEFAULT_BUDGET_USDC=0.01

# -----------------------------------------------------------------------------
# Circle Nanopayments  (https://console.circle.com/)
# When CIRCLE_API_KEY + CIRCLE_ENTITY_SECRET are set, paid reads use Circle
# Developer-Controlled Wallets on ARC-TESTNET. Fund the treasury wallet from
# https://faucet.circle.com/ before running the paid-read smoke test.
# -----------------------------------------------------------------------------
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENV=sandbox
CIRCLE_GATEWAY_BASE_URL=https://api.circle.com
HAYSTACK_SETTLEMENT_CURRENCY=USDC
CIRCLE_W3S_BLOCKCHAIN=ARC-TESTNET

# -----------------------------------------------------------------------------
# Arc network  (https://docs.arc.network/)
# Used to format explorer links on settlement records and (optionally) to
# resolve onchain transaction status. ARC_EXPLORER_BASE_URL alone is enough
# to make every receipt clickable in the dashboard.
# -----------------------------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000
ARC_EXPLORER_BASE_URL=https://testnet.arcscan.app
SETTLEMENT_CONFIRMATIONS_REQUIRED=1

# -----------------------------------------------------------------------------
# Tavily  (optional; only used by the validation skill, not by runtime)
# https://app.tavily.com/
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
